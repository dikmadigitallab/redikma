// Configuração do Client e Fonte de Dados
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---

enum UserStatus {
  ATIVO
  INATIVO
  PENDENTE
}

enum PostType {
  MANUAL
  AUTOMATICA_ANIVERSARIO
  AUTOMATICA_PROMOCAO
}

enum PostStatus {
  PUBLICADO
  AGENDADO
  RECORRENTE
}

// --- MODELOS ---

model Role {
  id    String @id @default(uuid())
  nome  String @unique // Admin Sistema, Admin Postador, Usuário Comum, RH
  users User[]
}

model JobTitle {
  id           String             @id @default(uuid())
  nome_cargo   String
  departamento String
  users        User[]
  // Relacionamentos para o histórico de promoções
  promocoes_de PromotionHistory[] @relation("CargoAnterior")
  promocoes_para PromotionHistory[] @relation("NovoCargo")
}

model User {
  id                        String             @id @default(uuid())
  cpf                       String             @unique
  nome_completo             String
  email_recuperacao         String?
  telefone                  String?
  senha_hash                String
  foto_url                  String?
  data_nascimento           DateTime
  data_admissao             DateTime
  primeiro_acesso           Boolean            @default(true)
  status                    UserStatus         @default(PENDENTE)
  data_exclusao_programada  DateTime?
  
  // Relacionamentos
  role_id                   String
  role                      Role               @relation(fields: [role_id], references: [id])
  cargo_id                  String
  cargo                     JobTitle           @relation(fields: [cargo_id], references: [id])
  
  posts                     Post[]
  visualizacoes             PostView[]
  curtidas                  Like[]
  comentarios               Comment[]
  reacoes                   Reaction[]
  historico_promocoes       PromotionHistory[]

  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt
}


model Post {
  id                        String      @id @default(uuid())
  tipo                      PostType    @default(MANUAL)
  mensagem                  String      @db.Text
  midia_url                 String?
  data_publicacao           DateTime    @default(now())
  status                    PostStatus  @default(PUBLICADO)
  configuracao_recorrencia  Json?       // Armazena regras de repetição
  visualizacoes_count       Int         @default(0)

  // Relacionamentos
  autor_id                  String
  autor                     User        @relation(fields: [autor_id], references: [id])
  
  visualizacoes_detalhe     PostView[]
  curtidas                  Like[]
  comentarios               Comment[]
  reacoes                   Reaction[]

  createdAt                 DateTime    @default(now())
}

model PostView {
  id         String   @id @default(uuid())
  data_hora  DateTime @default(now())
  
  post_id    String
  post       Post     @relation(fields: [post_id], references: [id])
  usuario_id String
  usuario    User     @relation(fields: [usuario_id], references: [id])

  @@index([post_id, usuario_id])
}

model Like {
  id         String @id @default(uuid())
  post_id    String
  post       Post   @relation(fields: [post_id], references: [id])
  usuario_id String
  usuario    User   @relation(fields: [usuario_id], references: [id])

  @@unique([post_id, usuario_id]) // Evita curtidas duplicadas
}

model Comment {
  id         String   @id @default(uuid())
  texto      String   @db.VarChar(100) // Limite de caracteres
  data_hora  DateTime @default(now())
  
  post_id    String
  post       Post     @relation(fields: [post_id], references: [id])
  usuario_id String
  usuario    User     @relation(fields: [usuario_id], references: [id])
}

model Reaction {
  id            String @id @default(uuid())
  emoji_unicode String
  
  post_id       String
  post          Post   @relation(fields: [post_id], references: [id])
  usuario_id    String
  usuario       User   @relation(fields: [usuario_id], references: [id])
}



model PromotionHistory {
  id                      String   @id @default(uuid())
  data_promocao           DateTime @default(now())
  post_automatico_gerado  Boolean  @default(false)

  usuario_id              String
  usuario                 User     @relation(fields: [usuario_id], references: [id])
  
  cargo_anterior_id       String
  cargo_anterior          JobTitle @relation("CargoAnterior", fields: [cargo_anterior_id], references: [id])
  
  novo_cargo_id           String
  novo_cargo              JobTitle @relation("NovoCargo", fields: [novo_cargo_id], references: [id])
}

model countLikesPerPost {
  post_id    String
  total      Int

  @@map("count_likes_per_post") // Mapeia para uma view ou tabela agregada
}

model coutnCommentsPerPost {
  post_id    String
  total      Int

  @@map("count_comments_per_post") // Mapeia para uma view ou tabela agregada
}

model countViewsPerPost {
  post_id    String
  total      Int

  @@map("count_views_per_post") // Mapeia para uma view ou tabela agregada
}
