generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Roles {
  SYSTEM_ADM
  ADMIN
  POSTADOR
  COMMON
}

enum post {
  ANIVERSARIO
  PROMOÇÃO
  TEMPODECASA
}



model autoPost {
  id        String @id @default(uuid())
  label     String
  author    String?
  type      post
  mensagem  String
  imagem    String?
  video     String?
}

model Postagem {
  id          String       @id @default(uuid())
  label       String
  authorId    String
  duration    String?
  publicado   Boolean      @default(false)
  image       String?
  video       String?
  author      User         @relation(fields: [authorId], references: [id])
  postador    String
  comentarios Comentario[]
  likes       Like[]
  createdAt   DateTime     @default(now())
}

model Like {
  id          String      @id @default(uuid())
  postId      String?
  post        Postagem?   @relation(fields: [postId], references: [id])
  comentarioId String?
  comentario   Comentario? @relation(fields: [comentarioId], references: [id])
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  createdAt   DateTime    @default(now())

  @@unique([postId, userId])
  @@unique([comentarioId, userId])
}

model Comentario {
  id        String    @id @default(uuid())
  texto     String
  aprovado  Boolean   @default(true)
  postId    String
  post      Postagem  @relation(fields: [postId], references: [id])
  authorId  String
  author    User      @relation(fields: [authorId], references: [id])
  createdAt DateTime  @default(now())
  likes     Like[]
}

model User {
  id          String       @id @default(uuid())
  nome        String
  username    String       @unique
  cpf         String       @unique
  cargo       String
  role        Roles        @default(COMMON)
  foto        String?
  postagens   Postagem[]
  comentarios Comentario[]
  likes       Like[]
  aniversario DateTime
  admissao    DateTime

}